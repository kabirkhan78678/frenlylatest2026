<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Email</title>
  <style type="text/css">
    * {
      font-family: "Poppins", Arial, sans-serif !important;
    }
  </style>
</head>
 
<body style="margin:0; padding:0;">
  <!-- Outer wrapper table -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" >
    <tr>
      <td align="center">
        <!-- Inner email container -->
        <table width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:10px;">
          
          <!-- Logo Section -->
          <tr style="background-color:#f5f5f5;">
            <td style="padding:15px; text-align:center;">
              <img src="https://www.frenly.se:4000/images/logo.png" 
                   style="display:block; margin:0 auto; width:120px;" 
                   alt="Frenly Logo">
            </td>
          </tr>
 
          <!-- Content Section -->
          <tr style="background-color:#ffffff;">
            <td style=" padding-top: 50px;padding-left:30px; padding-right: 30px;">
              <h3 style="text-align:center; margin:0 0 20px;">Verifiera ditt konto</h3>
              <p style="text-align:center; margin:0 0 40px; line-height:1.5;">
                Tack för att du registrerat ditt intresse hos Frenly. För att fortsätta, vänligen verifiera ditt konto genom att klicka på länken nedan.
              </p>
 
              <div style="text-align:center; margin-bottom:50px;">
                <a href="{{href_url}}"
                  style="background-color:#001649; padding:12px 24px; border-radius:5px; border:1px solid #001649; color:#ffffff; text-decoration:none; display:inline-block;">
                  Verifiera konto
                </a>
              </div>
 
              <h4 style="margin-bottom:10px;">Hälsningar,</h4>
              <p style="margin-top:0;">Frenly-teamet</p>
            </td>
          </tr>
 
          <!-- Footer Section -->
          <tr style="background-color:#001649;">
            <td style="padding:30px; text-align:center;">
              <p style="color:#ffffff; margin:0 0 10px;">Behöver du mer hjälp?</p>
              <a href="mailto:frenlyswe@gmail.com" 
                 style="color:#ffffff; text-decoration:underline;">
                 Vi finns här för att hjälpa dig.
              </a>
            </td>
          </tr>
 
        </table>
      </td>
    </tr>
  </table>
</body>
</html>